{
    "compilerOptions": {
        "module": "NodeNext",          // Updated to match moduleResolution
        "moduleResolution": "NodeNext", 
        "pretty": true,
        "sourceMap": false,
        "target": "ESNext",
        "outDir": "./dist",
        "noImplicitAny": false,
        "esModuleInterop": true,
        "removeComments": true,
        "preserveConstEnums": true,
        "experimentalDecorators": true,
        "alwaysStrict": true,
        "forceConsistentCasingInFileNames": true,
        "emitDecoratorMetadata": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strictPropertyInitialization": false
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.json",
        "server_config.json"
    ],
    "exclude": [
        "node_modules"
    ],
    "files": [
        "node_modules/@types/node/index.d.ts"
    ]
}